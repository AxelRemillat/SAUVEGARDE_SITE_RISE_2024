CREATE DATABASE rise;
USE rise;

CREATE TABLE Student (
    Id_student INT PRIMARY KEY AUTO_INCREMENT,
    Year INT,
    Last_name VARCHAR(100),
    First_name VARCHAR(100),
    Age INT,
    IELTS_score DECIMAL(3,1),
    GPA DECIMAL(4,2)
);

CREATE TABLE Testimony (
    Id_testimony INT PRIMARY KEY AUTO_INCREMENT,
    Validated BOOLEAN,
    Dates DATE,
    Content TEXT,
    Audio VARCHAR(255),
    PDF VARCHAR(255),
    Link VARCHAR(255),
    Video VARCHAR(255),
    Id_student INT,
    FOREIGN KEY (Id_student) REFERENCES Student(Id_student)
);

CREATE TABLE Uni (
    Id_uni INT PRIMARY KEY AUTO_INCREMENT,
    Name VARCHAR(100),
    Academic_surcharge DECIMAL(10,2),
    Semester_cost DECIMAL(10,2),
    IELTS_min DECIMAL(3,1),
    IELTS_max DECIMAL(3,1),
    Unique_IELTS DECIMAL(3,1) ,
    Number_of_students INT,
    Number_of_campuses INT,
    Founding_date DATE,
    Availability BOOLEAN,
    Semester_period VARCHAR(100),
    Registration_date DATE
);

CREATE TABLE Wish (
    Id_student INT,
    Id_uni INT,
    PRIMARY KEY (Id_student, Id_uni),
    FOREIGN KEY (Id_student) REFERENCES Student(Id_student),
    FOREIGN KEY (Id_uni) REFERENCES Uni(Id_uni)
);

CREATE TABLE Assign (
    Id_student INT,
    Id_uni INT,
    PRIMARY KEY (Id_student, Id_uni),
    FOREIGN KEY (Id_student) REFERENCES Student(Id_student),
    FOREIGN KEY (Id_uni) REFERENCES Uni(Id_uni)
);

CREATE TABLE Uni_year (
    Id_uni INT,
    Name VARCHAR(100),
    Academic_surcharge DECIMAL(10,2),
    Semester_cost DECIMAL(10,2),
    IELTS_min DECIMAL(3,1),
    IELTS_max DECIMAL(3,1),
    Unique_IELTS DECIMAL(3,1),
    Number_of_students INT,
    Number_of_campuses INT,
    Founding_date DATE,
    Availability BOOLEAN,
    Semester_period VARCHAR(100),
    Registration_date DATE,
   Id_city INT,
    Id_location INT,
    FOREIGN KEY (Id_uni) REFERENCES Uni(Id_uni),
    FOREIGN KEY (Id_city) REFERENCES City(Id_city),
    FOREIGN KEY (Id_location) REFERENCES Location(Id_location)
);

CREATE TABLE Country (
    Id_country INT PRIMARY KEY AUTO_INCREMENT,
    Country_name VARCHAR(100),
    Visa BOOLEAN,
    Country_safety VARCHAR(100)
);

CREATE TABLE City (
    Id_city INT PRIMARY KEY AUTO_INCREMENT,
    City_name VARCHAR(100),
    Housing VARCHAR(255),
    City_safety VARCHAR(100),
    Id_country INT,
    FOREIGN KEY (Id_country) REFERENCES Country(Id_country)
);

CREATE TABLE Location (
    Id_location INT PRIMARY KEY AUTO_INCREMENT,
    Continent VARCHAR(100),
    Address VARCHAR(255)
);
